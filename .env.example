# 1. EMOTIV Cortex API 인증 정보 (필수)
# Emotiv 마이페이지 -> App 탭에서 발급받은 값.
CLIENT_ID=2tdYbX8qfcj4hLmm4zwHBaDy0WQlPTE7mN9FSpKT
CLIENT_SECRET=여기에_발급받은_긴_비밀키_문자열을_넣으세요

# 2. Redis 서버 설정 (Upstash 클라우드 사용 시 REDIS_URL만 설정)
# 로컬 Docker 사용 시: REDIS_URL 주석 처리하면 REDIS_HOST/PORT 폴백
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# 3. 데이터 분석 및 장비 설정 (옵션)
SAMPLING_RATE=128

# Subject별 헤드셋 매핑 (EMOTIV Launcher > Devices에서 ID 확인)
# 1대만 사용 시 HEADSET_ID_1만 설정하면 됨
HEADSET_ID_1=INSIGHT-XXXXXXX
HEADSET_ID_2=INSIGHT-YYYYYYY

# 실시간 실험 시간 설정 (단위: 분)
EXPERIMENT_DURATION_MINUTES=10